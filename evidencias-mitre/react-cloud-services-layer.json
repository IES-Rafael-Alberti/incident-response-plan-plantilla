        {
          "action": "Remove malicious changes",
          "priority": 3,
          "attackTechniques": [
            "T1098",
            "T1538"
          ],
          "comment": "Elimina cambios maliciosos en usuarios, roles, grupos, reglas e integraciones."
        },
        {
          "action": "Rotate secrets",
          "priority": 3,
          "attackTechniques": [
            "T1528",
            "T1078.004"
          ],
          "comment": "Reduce reutilizacion de tokens, claves API y credenciales comprometidas."
        }
      ]
    },
